---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Badge from '@/components/ui/Badge.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Blog — Casos de Éxito | MUZA GROW"
  description="Casos de éxito reales con métricas comprobadas. Cómo MUZA GROW resuelve problemas operacionales en corporativos de LATAM."
>
  <Header />
  <main style="padding-top:5rem;">

    <section class="section" style="padding-top:4rem;padding-bottom:2rem;">
      <div class="s-tag">Casos de éxito</div>
      <h1 class="s-headline">
        Resultados reales,<br><em>métricas reales.</em>
      </h1>
      <p style="font-family:var(--body);font-size:1.05rem;color:var(--gr);line-height:1.75;max-width:600px;">
        No "case studies" inventados. Cada post documenta un proyecto real:
        el problema del cliente, lo que construimos y los resultados medibles.
      </p>
    </section>

    <section class="section" style="padding-top:0;padding-bottom:6rem;">
      {posts.length === 0 ? (
        <div style="text-align:center;padding:4rem;border:1px dashed var(--bdr);border-radius:1.5rem;">
          <div style="font-family:var(--mono);font-size:.6rem;color:var(--gr-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:1rem;">
            // próximamente
          </div>
          <p style="font-family:var(--body);font-size:1rem;color:var(--gr);max-width:400px;margin:0 auto;line-height:1.7;">
            Los primeros casos de éxito se publicarán conforme completemos proyectos.
            Honestidad sobre social proof fabricado.
          </p>
        </div>
      ) : (
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;">
          {posts.map(post => (
            <article class="card" style="display:flex;flex-direction:column;gap:.85rem;">
              <div style="display:flex;align-items:center;gap:.75rem;">
                <Badge color="teal">{post.data.industry}</Badge>
                <span style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);">
                  {post.data.pubDate.toLocaleDateString('es-MX', { month: 'long', year: 'numeric' })}
                </span>
              </div>

              <h2 style="font-family:var(--body);font-size:1.15rem;font-weight:700;line-height:1.3;">
                <a href={`/blog/${post.id}`} style="text-decoration:none;color:inherit;transition:color .2s;">
                  {post.data.title}
                </a>
              </h2>

              <p style="font-family:var(--body);font-size:.88rem;color:var(--gr);line-height:1.65;flex:1;">
                {post.data.excerpt}
              </p>

              {post.data.metrics && (
                <div style="display:flex;gap:1rem;flex-wrap:wrap;padding:.9rem;background:var(--s2);border-radius:.75rem;border:1px solid var(--bdr);">
                  {post.data.metrics.map((m: { label: string; value: string }) => (
                    <div style="display:flex;flex-direction:column;gap:.2rem;">
                      <span style="font-family:var(--mono);font-size:1.4rem;font-weight:700;color:var(--teal);line-height:1;">{m.value}</span>
                      <span style="font-family:var(--mono);font-size:.48rem;color:var(--gr-d);letter-spacing:.15em;text-transform:uppercase;">{m.label}</span>
                    </div>
                  ))}
                </div>
              )}

              <a href={`/blog/${post.id}`} style="font-family:var(--mono);font-size:.6rem;color:var(--gold);letter-spacing:.13em;text-decoration:none;text-transform:uppercase;display:inline-flex;align-items:center;gap:.4rem;transition:gap .2s;margin-top:.3rem;">
                LEER CASO →
              </a>
            </article>
          ))}
        </div>
      )}
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
@media (max-width: 860px) {
  div[style*="grid-template-columns:repeat(3,1fr)"] {
    grid-template-columns: 1fr !important;
  }
}
</style>
