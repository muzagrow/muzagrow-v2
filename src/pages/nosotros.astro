---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Button from '@/components/ui/Button.astro';
import { TOOLS } from '@/lib/constants';
---

<BaseLayout
  title="Nosotros | MUZA GROW"
  description="Service Design + Automatización IA para corporativos en LATAM. Conoce la historia y filosofía detrás de MUZA GROW."
>
  <Header />
  <main style="padding-top:5rem;">

    <!-- Hero -->
    <section class="section" style="padding-top:4rem;padding-bottom:4rem;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;">
        <div>
          <div class="s-tag">Quiénes somos</div>
          <h1 class="s-headline">
            Service Design<br><em>para operaciones que escalan.</em>
          </h1>
          <p style="font-family:var(--body);font-size:1.05rem;color:var(--gr);line-height:1.75;margin-bottom:1.5rem;">
            MUZA GROW nació de una convicción: las empresas medianas y grandes en LATAM
            tienen los equipos, la visión y el mercado — pero sus operaciones no escalan al mismo ritmo.
          </p>
          <p style="font-family:var(--body);font-size:1.05rem;color:var(--white);line-height:1.75;">
            No vendemos "automatización". Diseñamos la infraestructura operacional
            que permite que tu empresa crezca sin fricciones.
          </p>
        </div>

        <!-- Moises card -->
        <div class="card" style="padding:2.5rem;">
          <div style="display:flex;align-items:center;gap:1.5rem;margin-bottom:2rem;">
            <div style="width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--coral));display:flex;align-items:center;justify-content:center;font-size:2rem;flex-shrink:0;">
              M
            </div>
            <div>
              <div style="font-family:var(--mono);font-size:.58rem;color:var(--gr);letter-spacing:.1em;">SERVICE DESIGNER + GROWTH ARCHITECT</div>
            </div>
          </div>

          <p style="font-family:var(--body);font-size:.92rem;color:var(--gr);line-height:1.75;margin-bottom:1.5rem;">
            Especialista en diseño de servicios e infraestructura de crecimiento.
            Cada cliente es una oportunidad de aprendizaje real — lo que Moises construye
            contigo también es su mejor portafolio.
          </p>

          <div style="display:flex;flex-direction:column;gap:.7rem;margin-bottom:1.5rem;">
            {[
              '🎓 Universidad Unicornio — Service Design',
              '🛠 n8n Certified Expert',
              '🤖 AI Systems Architect',
              '📊 Growth Strategy Consultant',
            ].map(item => (
              <div style="font-family:var(--mono);font-size:.6rem;color:var(--gr);letter-spacing:.04em;display:flex;align-items:center;gap:.65rem;">
                {item}
              </div>
            ))}
          </div>

          <div style="padding:.9rem;background:var(--s2);border:1px solid var(--bdr);border-radius:.8rem;font-family:var(--mono);font-size:.6rem;color:var(--gr);line-height:1.6;">
            💡 "Aprendemos haciendo. Cada cliente = proyecto real + caso de estudio + mejora del proceso. No cobramos por experimentar."
          </div>
        </div>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="section" style="padding-top:0;">
      <div class="s-tag">Filosofía</div>
      <h2 class="s-headline">Lo que nos guía<br><em>en cada proyecto.</em></h2>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.2rem;">
        {[
          {
            num: '01',
            title: 'Service Designer primero',
            desc: 'Entendemos el problema antes de proponer soluciones. Diseñamos sistemas, no solo flujos.',
          },
          {
            num: '02',
            title: 'Resultados sobre herramientas',
            desc: 'No vendemos n8n ni IA. Vendemos el resultado de usarlos bien. La herramienta es el medio, no el fin.',
          },
          {
            num: '03',
            title: 'Moises habla directo contigo',
            desc: 'Sin intermediarios, sin ventas de alta presión. Conversación real con la persona que va a construirlo.',
          },
          {
            num: '04',
            title: 'Honestidad sobre viabilidad',
            desc: 'Si algo no tiene sentido construirlo, te lo decimos. Preferimos una relación honesta a un proyecto mal enfocado.',
          },
          {
            num: '05',
            title: 'Cada cliente enseña algo',
            desc: 'Cada proyecto es una oportunidad de mejorar. Documentamos lo que aprendemos y lo aplicamos al siguiente.',
          },
          {
            num: '06',
            title: 'Métricas reales, no vanidad',
            desc: 'Medimos lo que importa: horas ahorradas, costos reducidos, ingresos aumentados. No "deploys" ni "sprints".',
          },
        ].map(item => (
          <div class="card">
            <div style="font-family:var(--mono);font-size:3rem;font-weight:700;color:rgba(243,198,99,.06);margin-bottom:.75rem;">{item.num}</div>
            <h3 style="font-family:var(--body);font-size:1.05rem;font-weight:700;margin-bottom:.75rem;">{item.title}</h3>
            <p style="font-family:var(--body);font-size:.88rem;color:var(--gr);line-height:1.65;">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Universidad Unicornio mention -->
    <section class="section" style="padding-top:0;">
      <div class="card" style="padding:3rem;background:rgba(0,168,143,.04);border-color:rgba(0,168,143,.2);">
        <div style="display:grid;grid-template-columns:2fr 1fr;gap:3rem;align-items:center;">
          <div>
            <div class="s-tag">Aprendizaje continuo</div>
            <h2 style="font-family:var(--body);font-size:clamp(1.8rem,3vw,2.5rem);font-weight:800;margin-bottom:1.2rem;">
              Universidad Unicornio:<br>
              <em style="font-family:var(--ser);color:var(--teal);font-weight:400;font-style:italic;">Cada cliente = proyecto real</em>
            </h2>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--gr);line-height:1.75;margin-bottom:1rem;">
              Moises aplica la metodología de Universidad Unicornio: aprende resolviendo
              problemas reales. Cada proyecto MUZA GROW se convierte en:
            </p>
            <ul style="list-style:none;display:flex;flex-direction:column;gap:.6rem;">
              {[
                'Caso de estudio real (métricas comprobadas)',
                'Entrada al portafolio Behance',
                'Checkpoint de aprendizaje de Service Design',
                'Mejora del proceso para el siguiente cliente',
              ].map(item => (
                <li style="font-family:var(--body);font-size:.9rem;color:var(--white);display:flex;align-items:center;gap:.65rem;">
                  <span style="width:6px;height:6px;background:var(--teal);border-radius:50%;flex-shrink:0;"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div style="text-align:center;">
            <div style="font-family:var(--mono);font-size:5rem;font-weight:700;color:var(--teal);line-height:1;">∞</div>
            <div style="font-family:var(--mono);font-size:.58rem;color:var(--gr);letter-spacing:.2em;text-transform:uppercase;margin-top:.5rem;">LEARN BY DOING</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="section" style="padding-top:0;padding-bottom:5rem;">
      <div class="s-tag">Stack</div>
      <h2 class="s-headline" style="margin-bottom:2rem;">Herramientas<br><em>que dominamos.</em></h2>
      <div style="display:flex;flex-wrap:wrap;gap:.55rem;">
        {TOOLS.map(t => (
          <div style="font-family:var(--mono);font-size:.62rem;color:var(--gr);background:var(--s2);border:1px solid var(--bdr);padding:.45rem 1rem;border-radius:20px;letter-spacing:.05em;transition:color .2s,border-color .2s;cursor:default;">
            {t}
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section style="text-align:center;padding:4rem var(--px) 6rem;position:relative;z-index:2;">
      <h2 style="font-family:var(--body);font-size:clamp(2rem,4vw,3rem);font-weight:800;margin-bottom:1.2rem;">
        Trabajemos juntos
      </h2>
      <p style="font-family:var(--body);font-size:1rem;color:var(--gr);max-width:480px;margin:0 auto 2rem;line-height:1.7;">
        Una conversación con Moises, sin compromiso. Entendemos tu problema antes de proponer cualquier solución.
      </p>
      <Button href="/contacto" size="lg">Agendar diagnóstico gratuito →</Button>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
@media (max-width: 768px) {
  div[style*="grid-template-columns:1fr 1fr"],
  div[style*="grid-template-columns:2fr 1fr"] {
    grid-template-columns: 1fr !important;
  }
  div[style*="grid-template-columns:repeat(3,1fr)"] {
    grid-template-columns: 1fr !important;
  }
}
</style>
