---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
---

<BaseLayout
  title="Servicios | MUZA GROW"
  description="Growth Architecture Discovery, Automation Design & Build, y Ongoing Optimization. Service Design para corporativos en LATAM."
>
  <Header />
  <main style="padding-top:5rem;">

    <!-- Hero -->
    <section class="section" style="padding-top:4rem;padding-bottom:2rem;">
      <div class="s-tag">Protocolos</div>
      <h1 class="s-headline">
        Servicios diseñados<br><em>para tu problema exacto.</em>
      </h1>
      <p style="font-family:var(--body);font-size:1.05rem;color:var(--gr);line-height:1.75;max-width:600px;">
        No vendemos paquetes genéricos. Cada cliente pasa por Discovery primero.
        Porque cada problema operacional es único y merece una solución diseñada específicamente para él.
      </p>
    </section>

    <!-- Service 1: Discovery -->
    <section class="section" id="discovery" style="padding-top:0;">
      <article class="card" style="padding:3rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
          <div>
            <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.15em;margin-bottom:1rem;">/ 01 — FUNDACIÓN</div>
            <h2 style="font-family:var(--body);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin-bottom:1.5rem;">
              Growth Architecture<br>
              <em style="font-family:var(--ser);color:var(--teal);font-style:italic;font-weight:400;">Discovery</em>
            </h2>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--gr);line-height:1.75;margin-bottom:1.5rem;">
              Antes de construir cualquier cosa, necesitamos entender tu operación real.
              En sesiones directas con Moises, mapeamos procesos, identificamos cuellos de botella
              y diseñamos la arquitectura de la solución ideal.
            </p>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--white);line-height:1.75;">
              El resultado es un <strong>strategy document + execution roadmap</strong> que sirve
              como guía para la fase de construcción. Sin ambigüedad. Sin suposiciones.
            </p>
          </div>
          <div style="display:flex;flex-direction:column;gap:1.2rem;">
            <div style="background:var(--s2);border:1px solid var(--bdr);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.85rem;">Incluye</div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:.65rem;">
                {['Sesiones de discovery con Moises', 'Mapeo de procesos actuales', 'Identificación de oportunidades de automatización', 'Architecture design document', 'Execution roadmap con timelines', 'Estimado de ROI'].map(item => (
                  <li style="font-family:var(--body);font-size:.88rem;color:var(--gr);display:flex;align-items:center;gap:.65rem;">
                    <span style="width:5px;height:5px;background:var(--teal);border-radius:50%;flex-shrink:0;"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div style="background:rgba(0,168,143,.06);border:1px solid rgba(0,168,143,.2);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--teal);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.65rem;">Entregable</div>
              <p style="font-family:var(--body);font-size:.95rem;color:var(--white);font-weight:600;">Strategy document + execution roadmap</p>
              <p style="font-family:var(--mono);font-size:.6rem;color:var(--gr);margin-top:.4rem;">Para quién: Empresas que no saben por dónde empezar</p>
            </div>
          </div>
        </div>
        <div style="margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--bdr);display:flex;gap:1rem;">
          <Button href="/contacto">Agendar Discovery</Button>
          <Button href="/contacto" variant="outline">Hacer preguntas primero</Button>
        </div>
      </article>
    </section>

    <!-- Service 2: Build -->
    <section class="section" id="build" style="padding-top:0;">
      <article class="card" style="padding:3rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
          <div>
            <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.15em;margin-bottom:1rem;">/ 02 — CONSTRUCCIÓN</div>
            <h2 style="font-family:var(--body);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin-bottom:1.5rem;">
              Automation Design<br>
              <em style="font-family:var(--ser);color:var(--orange);font-style:italic;font-weight:400;">& Build</em>
            </h2>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--gr);line-height:1.75;margin-bottom:1.5rem;">
              Con el roadmap en mano, construimos. Diseñamos los workflows, seleccionamos
              las herramientas correctas y construimos el sistema completo: n8n flows,
              AI agents, integraciones y dashboards.
            </p>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--white);line-height:1.75;">
              Desplegamos, testeamos y entregamos con <strong>documentación completa</strong>.
              Tu equipo puede operarlo desde el día 1.
            </p>
          </div>
          <div style="display:flex;flex-direction:column;gap:1.2rem;">
            <div style="background:var(--s2);border:1px solid var(--bdr);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.85rem;">Incluye</div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:.65rem;">
                {['Diseño de workflows y arquitectura', 'Build con n8n + AI agents', 'Integraciones con tus herramientas', 'Testing & QA riguroso', 'Deployment en producción', 'Documentación técnica', 'Training de tu equipo'].map(item => (
                  <li style="font-family:var(--body);font-size:.88rem;color:var(--gr);display:flex;align-items:center;gap:.65rem;">
                    <span style="width:5px;height:5px;background:var(--orange);border-radius:50%;flex-shrink:0;"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div style="background:rgba(243,169,61,.06);border:1px solid rgba(243,169,61,.2);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--orange);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.65rem;">Entregable</div>
              <p style="font-family:var(--body);font-size:.95rem;color:var(--white);font-weight:600;">Sistema automático funcionando en producción</p>
              <p style="font-family:var(--mono);font-size:.6rem;color:var(--gr);margin-top:.4rem;">Para quién: Empresas que ya saben qué quieren construir</p>
            </div>
          </div>
        </div>
        <div style="margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--bdr);display:flex;gap:1rem;">
          <Button href="/contacto">Iniciar proyecto</Button>
          <Button href="/proceso" variant="outline">Ver nuestro proceso</Button>
        </div>
      </article>
    </section>

    <!-- Service 3: Optimize -->
    <section class="section" id="optimize" style="padding-top:0;">
      <article class="card" style="padding:3rem;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;">
          <div>
            <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.15em;margin-bottom:1rem;">/ 03 — CRECIMIENTO</div>
            <h2 style="font-family:var(--body);font-size:clamp(2rem,4vw,3rem);font-weight:800;letter-spacing:-.02em;line-height:1.1;margin-bottom:1.5rem;">
              Ongoing<br>
              <em style="font-family:var(--ser);color:var(--coral);font-style:italic;font-weight:400;">Optimization</em>
            </h2>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--gr);line-height:1.75;margin-bottom:1.5rem;">
              Lanzar es el inicio, no el fin. Monitoreamos performance, identificamos
              oportunidades de mejora y escalamos el sistema conforme tu negocio crece.
            </p>
            <p style="font-family:var(--body);font-size:.95rem;color:var(--white);line-height:1.75;">
              Cada iteración se basa en <strong>métricas reales</strong>, no en suposiciones.
              ROI medible, comprobable, documentado.
            </p>
          </div>
          <div style="display:flex;flex-direction:column;gap:1.2rem;">
            <div style="background:var(--s2);border:1px solid var(--bdr);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--gr-d);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.85rem;">Incluye</div>
              <ul style="list-style:none;display:flex;flex-direction:column;gap:.65rem;">
                {['Monitoring de performance mensual', 'Análisis de métricas y KPIs', 'Iteraciones basadas en datos', 'Nuevas automatizaciones según necesidad', 'Escalabilidad del sistema', 'Reportes de ROI'].map(item => (
                  <li style="font-family:var(--body);font-size:.88rem;color:var(--gr);display:flex;align-items:center;gap:.65rem;">
                    <span style="width:5px;height:5px;background:var(--coral);border-radius:50%;flex-shrink:0;"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
            <div style="background:rgba(238,118,93,.06);border:1px solid rgba(238,118,93,.2);border-radius:1rem;padding:1.5rem;">
              <div style="font-family:var(--mono);font-size:.55rem;color:var(--coral);letter-spacing:.2em;text-transform:uppercase;margin-bottom:.65rem;">Entregable</div>
              <p style="font-family:var(--body);font-size:.95rem;color:var(--white);font-weight:600;">Continuous improvement + métricas de ROI comprobadas</p>
              <p style="font-family:var(--mono);font-size:.6rem;color:var(--gr);margin-top:.4rem;">Para quién: Empresas que lanzaron y quieren mejorar</p>
            </div>
          </div>
        </div>
        <div style="margin-top:2.5rem;padding-top:2rem;border-top:1px solid var(--bdr);display:flex;gap:1rem;">
          <Button href="/contacto">Activar optimización</Button>
        </div>
      </article>
    </section>

    <!-- CTA -->
    <section class="section" style="text-align:center;padding-bottom:6rem;">
      <h2 style="font-family:var(--body);font-size:clamp(2rem,4vw,3rem);font-weight:800;margin-bottom:1.5rem;">
        ¿No sabes cuál servicio necesitas?
      </h2>
      <p style="font-family:var(--body);font-size:1rem;color:var(--gr);max-width:500px;margin:0 auto 2rem;line-height:1.7;">
        Empieza con Discovery. Moises te ayuda a entender qué construir antes de invertir en construirlo.
      </p>
      <Button href="/contacto" size="lg">Empezar con diagnóstico gratuito →</Button>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
@media (max-width: 768px) {
  .card > div[style*="grid-template-columns:1fr 1fr"] {
    grid-template-columns: 1fr !important;
    gap: 2rem !important;
  }
}
</style>
