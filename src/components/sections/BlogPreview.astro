---
import { getCollection } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

{posts.length > 0 && (
  <section class="section" id="blog" aria-labelledby="blog-h">
    <div class="s-tag">Casos de éxito</div>
    <h2 class="s-headline" id="blog-h">
      Resultados<br><em>reales, métricas reales.</em>
    </h2>

    <div class="blog-grid">
      {posts.map(post => (
        <article class="card blog-card">
          <div class="blog-meta">
            <Badge color="teal">{post.data.industry}</Badge>
            <span class="blog-date">{post.data.pubDate.toLocaleDateString('es-MX', { month: 'short', year: 'numeric' })}</span>
          </div>

          <h3 class="blog-title">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </h3>

          <p class="blog-excerpt">{post.data.excerpt}</p>

          {post.data.metrics && (
            <div class="blog-metrics">
              {post.data.metrics.map((m: { label: string; value: string }) => (
                <div class="blog-metric">
                  <span class="blog-metric-val">{m.value}</span>
                  <span class="blog-metric-lbl">{m.label}</span>
                </div>
              ))}
            </div>
          )}

          <a href={`/blog/${post.id}`} class="blog-link">LEER CASO →</a>
        </article>
      ))}
    </div>

    <div style="text-align:center;margin-top:3rem;">
      <a href="/blog" class="view-all-link">Ver todos los casos →</a>
    </div>
  </section>
)}

<style>
.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.2rem;
}
@media (max-width: 860px) { .blog-grid { grid-template-columns: 1fr; } }
@media (max-width: 1100px) and (min-width: 861px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }

.blog-card { display: flex; flex-direction: column; gap: .85rem; }
.blog-meta { display: flex; align-items: center; gap: .75rem; }
.blog-date { font-family: var(--mono); font-size: .55rem; color: var(--gr-d); }

.blog-title {
  font-family: var(--body); font-size: 1.15rem; font-weight: 700;
  line-height: 1.3; color: var(--white);
}
.blog-title a { text-decoration: none; color: inherit; transition: color .2s; }
.blog-title a:hover { color: var(--teal); }

.blog-excerpt { font-family: var(--body); font-size: .88rem; color: var(--gr); line-height: 1.65; flex: 1; }

.blog-metrics {
  display: flex; gap: 1.2rem; flex-wrap: wrap;
  padding: .9rem; background: var(--s2); border-radius: .75rem;
  border: 1px solid var(--bdr);
}
.blog-metric { display: flex; flex-direction: column; gap: .2rem; }
.blog-metric-val {
  font-family: var(--mono); font-size: 1.4rem; font-weight: 700;
  color: var(--teal); line-height: 1;
}
.blog-metric-lbl {
  font-family: var(--mono); font-size: .48rem; color: var(--gr-d);
  letter-spacing: .15em; text-transform: uppercase;
}

.blog-link {
  font-family: var(--mono); font-size: .6rem; color: var(--gold);
  letter-spacing: .13em; text-decoration: none; text-transform: uppercase;
  display: inline-flex; align-items: center; gap: .4rem;
  transition: gap .2s; margin-top: .3rem;
}
.blog-link:hover { gap: .8rem; }

.view-all-link {
  font-family: var(--mono); font-size: .65rem; color: var(--gr);
  letter-spacing: .12em; text-decoration: none; text-transform: uppercase;
  transition: color .2s;
}
.view-all-link:hover { color: var(--white); }
</style>
