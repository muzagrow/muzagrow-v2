---
import { getCollection } from 'astro:content';
import Badge from '@/components/ui/Badge.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<section class="section" id="blog" aria-labelledby="blog-h">
  <div class="blog-header">
    <div>
      <div class="s-tag">Blog</div>
      <h2 class="s-headline" id="blog-h">
        Lo que aprendemos<br><em>mientras construimos.</em>
      </h2>
    </div>
    <a href="/blog" class="blog-all-link">Ver todas las publicaciones →</a>
  </div>

  {posts.length === 0 ? (
    <div class="blog-empty">
      <div class="blog-empty-tag">// próximamente</div>
      <p class="blog-empty-text">
        Los primeros artículos se publican conforme avanzamos con proyectos reales.
        Preferimos cero artículos honestos que diez inventados.
      </p>
    </div>
  ) : (
    <div class="blog-grid">
      {posts.map((post, i) => (
        <article class:list={['blog-card', { 'blog-card--featured': i === 0 }]}>
          <div class="blog-card-meta">
            <Badge color="teal">{post.data.industry}</Badge>
            <span class="blog-card-date">
              {post.data.pubDate.toLocaleDateString('es-MX', { month: 'short', year: 'numeric' })}
            </span>
          </div>
          <h3 class="blog-card-title">
            <a href={`/blog/${post.id}`}>{post.data.title}</a>
          </h3>
          <p class="blog-card-excerpt">{post.data.excerpt}</p>
          <a href={`/blog/${post.id}`} class="blog-card-link">Leer más →</a>
        </article>
      ))}
    </div>
  )}
</section>

<style>
.blog-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 2rem;
  margin-bottom: 0;
}
.blog-header .s-headline { margin-bottom: 0; }

.blog-all-link {
  font-family: var(--mono);
  font-size: .6rem;
  color: var(--gr);
  letter-spacing: .12em;
  text-decoration: none;
  text-transform: uppercase;
  white-space: nowrap;
  transition: color .2s;
  flex-shrink: 0;
  padding-bottom: .5rem;
}
.blog-all-link:hover { color: var(--white); }

@media (max-width: 600px) {
  .blog-header { flex-direction: column; align-items: flex-start; }
}

/* Grid */
.blog-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr 1fr;
  gap: 1.2rem;
  margin-top: 2.5rem;
}
@media (max-width: 900px) {
  .blog-grid { grid-template-columns: 1fr 1fr; }
  .blog-card--featured { grid-column: span 2; }
}
@media (max-width: 560px) {
  .blog-grid { grid-template-columns: 1fr; }
  .blog-card--featured { grid-column: span 1; }
}

/* Card base */
.blog-card {
  background: var(--s1);
  border: 1px solid var(--bdr);
  border-radius: 1.5rem;
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: .9rem;
  transition: border-color .3s, transform .3s;
  min-width: 0;
}
.blog-card:hover {
  border-color: var(--bdr-g);
  transform: translateY(-3px);
}

/* Featured card más grande */
.blog-card--featured {
  padding: 2.4rem;
  background: rgba(0,168,143,.04);
  border-color: rgba(0,168,143,.15);
}
.blog-card--featured .blog-card-title {
  font-size: clamp(1.15rem, 2.5vw, 1.4rem);
}

/* Meta */
.blog-card-meta {
  display: flex;
  align-items: center;
  gap: .75rem;
}
.blog-card-date {
  font-family: var(--mono);
  font-size: .55rem;
  color: var(--gr-d);
  letter-spacing: .08em;
}

/* Título */
.blog-card-title {
  font-family: var(--body);
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.35;
  overflow-wrap: break-word;
}
.blog-card-title a {
  text-decoration: none;
  color: var(--white);
  transition: color .2s;
}
.blog-card-title a:hover { color: var(--teal); }

/* Excerpt */
.blog-card-excerpt {
  font-family: var(--body);
  font-size: .85rem;
  color: var(--gr);
  line-height: 1.7;
  flex: 1;
  overflow-wrap: break-word;
  /* Limitar a 3 líneas en cards pequeñas */
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.blog-card--featured .blog-card-excerpt {
  -webkit-line-clamp: 5;
}

/* Link */
.blog-card-link {
  font-family: var(--mono);
  font-size: .58rem;
  color: var(--teal);
  letter-spacing: .1em;
  text-decoration: none;
  text-transform: uppercase;
  transition: letter-spacing .2s;
  margin-top: auto;
}
.blog-card-link:hover { letter-spacing: .16em; }

/* Empty state */
.blog-empty {
  margin-top: 2rem;
  padding: 3rem 2rem;
  border: 1px dashed var(--bdr);
  border-radius: 1.5rem;
  text-align: center;
}
.blog-empty-tag {
  font-family: var(--mono);
  font-size: .6rem;
  color: var(--gr-d);
  letter-spacing: .2em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.blog-empty-text {
  font-family: var(--body);
  font-size: .95rem;
  color: var(--gr);
  max-width: 420px;
  margin: 0 auto;
  line-height: 1.7;
}
</style>
