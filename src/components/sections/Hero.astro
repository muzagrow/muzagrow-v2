---
import Button from '@/components/ui/Button.astro';
---

<section id="hero">
  <!-- Glow de fondo -->
  <div class="hero-glow" aria-hidden="true"></div>

  <!-- Esfera Three.js — fondo decorativo absoluto -->
  <div id="sphere-wrap" role="img" aria-label="MUZA CORE">
    <canvas id="three-canvas"></canvas>
  </div>

  <!-- Contenido principal — siempre visible -->
  <div class="hero-content">

    <!-- Badge superior -->
    <div class="hero-badge">
      <span class="badge-br">[</span>&nbsp;MUZA_CORE&nbsp;<span class="badge-br">]</span>
    </div>

    <!-- Headlines -->
    <h1 class="hero-h1">
      <span class="hero-h1-white">RESOLVEMOS TUS</span>
      <span class="hero-h1-holo holo-text">PROBLEMAS OPERACIONALES.</span>
    </h1>

    <p class="hero-sub">
      No vendemos herramientas. Diseñamos infraestructura para que tu equipo
      haga lo que importa. El resto? Automático.
    </p>

    <!-- CTAs -->
    <div class="hero-ctas">
      <Button href="/contacto" size="lg">⚙ Agendar diagnóstico</Button>
      <Button href="/contacto#form" variant="outline" size="lg">Cuéntame tu desafío</Button>
    </div>

    <!-- Metrics -->
    <div id="metrics" aria-label="Métricas de desempeño">
      <div class="met">
        <span class="met-num" data-t="300">300</span><span class="met-sfx">%+</span>
        <div class="met-lbl">ROI automatización</div>
      </div>
      <div class="met">
        <span class="met-num" data-t="48">48</span><span class="met-sfx">h</span>
        <div class="met-lbl">Deploy garantizado</div>
      </div>
      <div class="met">
        <span class="met-num" data-t="24">24</span><span class="met-sfx">/7</span>
        <div class="met-lbl">Sistemas activos</div>
      </div>
      <div class="met">
        <span class="met-num" data-t="12">12</span><span class="met-sfx">x</span>
        <div class="met-lbl">Velocidad operativa</div>
      </div>
    </div>
  </div>
</section>

<!-- Sticky Dock -->
<div id="dock">
  <div class="dock-inner">
    <div class="dock-term" aria-hidden="true">&gt;_</div>
    <div class="dock-actions">
      <a href="/" class="dock-outline"><span class="br">[</span>&nbsp;INICIO&nbsp;<span class="br">]</span></a>
      <a href="/contacto" class="dock-cta">⚙&nbsp;AGENDAR DIAGNÓSTICO</a>
    </div>
    <div class="dock-loc">
      <span>📍 CIUDAD DE MÉXICO / GLOBAL</span>
    </div>
  </div>
</div>

<style>
#hero {
  position: relative;
  z-index: 1;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 6rem var(--px) 4rem;
  overflow: hidden;
}

/* Esfera como fondo absoluto */
#sphere-wrap {
  position: absolute;
  top: 50%;
  right: -5%;
  transform: translateY(-50%);
  width: clamp(280px, 45vw, 560px);
  height: clamp(280px, 45vw, 560px);
  z-index: 0;
  opacity: .85;
  pointer-events: none;
}
#sphere-wrap canvas { width: 100% !important; height: 100% !important; }

@media (max-width: 768px) {
  #sphere-wrap {
    right: 50%;
    transform: translate(50%, -50%);
    opacity: .3;
    width: min(90vw, 360px);
    height: min(90vw, 360px);
  }
}

.hero-glow {
  position: absolute;
  top: 50%; left: 60%;
  transform: translate(-50%, -50%);
  width: min(600px, 90vw);
  height: min(600px, 90vw);
  background: radial-gradient(ellipse, rgba(0,168,143,.08) 0%, rgba(243,198,99,.05) 40%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* Contenido */
.hero-content {
  position: relative;
  z-index: 2;
  max-width: 700px;
  width: 100%;
}

.hero-badge {
  font-family: var(--mono);
  font-size: .68rem;
  letter-spacing: .28em;
  color: var(--white);
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  backdrop-filter: blur(8px);
  padding: .45rem 1.3rem;
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  border-radius: 2rem;
  margin-bottom: 2rem;
}
.badge-br { color: var(--teal); opacity: .8; }

.hero-h1 {
  font-family: var(--body);
  font-weight: 800;
  letter-spacing: -.03em;
  line-height: 1.02;
  margin-bottom: 1.5rem;
}
.hero-h1-white {
  font-size: clamp(2.8rem, 6vw, 6.5rem);
  color: var(--white);
  display: block;
}
.hero-h1-holo {
  font-size: clamp(2.8rem, 6vw, 6.5rem);
  display: block;
}

.hero-sub {
  font-family: var(--body);
  font-size: clamp(.95rem, 1.8vw, 1.1rem);
  color: var(--gr);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 2.5rem;
}

.hero-ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

/* Metrics */
#metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--bdr);
  background: var(--s1);
  backdrop-filter: blur(12px);
  border-radius: 1.5rem;
  max-width: 600px;
}
@media (max-width: 560px) {
  #metrics { grid-template-columns: repeat(2, 1fr); }
  .met:nth-child(2) { border-right: none; }
  .met:nth-child(1), .met:nth-child(2) { border-bottom: 1px solid var(--bdr); }
}
.met { padding: 1rem; text-align: center; border-right: 1px solid var(--bdr); }
.met:last-child { border-right: none; }
.met-num {
  font-family: var(--mono);
  font-size: clamp(1.2rem, 2.5vw, 1.8rem);
  font-weight: 700;
  color: var(--white);
  line-height: 1;
  display: inline;
}
.met-sfx { font-family: var(--mono); font-size: .75em; color: var(--gold); }
.met-lbl {
  font-family: var(--mono);
  font-size: clamp(.4rem, .9vw, .5rem);
  color: var(--gr);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-top: .35rem;
}
</style>

<script>
/* Counter animation */
(function () {
  if (!('IntersectionObserver' in window)) return;
  document.querySelectorAll('.met-num[data-t]').forEach(el => {
    const target = +(el as HTMLElement).dataset.t!;
    el.textContent = String(target);
    const obs = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) return;
      obs.disconnect();
      let t0: number | null = null;
      const dur = 1800;
      function step(ts: number) {
        if (!t0) t0 = ts;
        const p = Math.min((ts - t0) / dur, 1);
        el.textContent = String(Math.round(p * target));
        if (p < 1) requestAnimationFrame(step);
        else el.textContent = String(target);
      }
      requestAnimationFrame(step);
    }, { threshold: .5 });
    obs.observe(el);
  });
})();
</script>

<!-- Three.js sphere — decorativo, opcional -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r145/three.min.js" defer></script>
<script defer>
window.addEventListener('load', function () {
  if (typeof THREE === 'undefined') return;
  try {
    const wrap = document.getElementById('sphere-wrap');
    const canvas = document.getElementById('three-canvas');
    if (!wrap || !canvas) return;
    const W = wrap.offsetWidth, H = wrap.offsetHeight;
    if (!W || !H) return;
    const scene = new THREE.Scene();
    const cam = new THREE.PerspectiveCamera(45, W / H, .1, 100);
    cam.position.z = 3.8;
    const rend = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    rend.setSize(W, H); rend.setPixelRatio(Math.min(devicePixelRatio, 2));
    rend.setClearColor(0, 0);
    scene.add(new THREE.AmbientLight(0xffffff, 0.5));
    const pl1 = new THREE.PointLight(0xffffff, 1.5, 100);
    pl1.position.set(5, 5, 5); scene.add(pl1);
    const pl2 = new THREE.PointLight(0xEE765D, 2, 100);
    pl2.position.set(-5, -5, -2); scene.add(pl2);
    const group = new THREE.Group(); scene.add(group);
    const sphere = new THREE.Mesh(
      new THREE.SphereGeometry(1.0, 32, 32),
      new THREE.MeshPhysicalMaterial({ color: 0x00A88F, roughness: 0.2, metalness: 0.1, clearcoat: 1.0, clearcoatRoughness: 0.1 })
    );
    sphere.position.set(-0.3, 0.2, 0); group.add(sphere);
    const cvs2 = document.createElement('canvas'); cvs2.width = 1; cvs2.height = 256;
    const ctx2 = cvs2.getContext('2d');
    const grad = ctx2.createLinearGradient(0, 0, 0, 256);
    grad.addColorStop(0, '#F3C663'); grad.addColorStop(1, '#EE765D');
    ctx2.fillStyle = grad; ctx2.fillRect(0, 0, 1, 256);
    const cap = new THREE.Mesh(
      new THREE.CapsuleGeometry(0.35, 0.8, 4, 32),
      new THREE.MeshPhysicalMaterial({ map: new THREE.CanvasTexture(cvs2), roughness: 0.3, metalness: 0.1 })
    );
    cap.position.set(1.0, -0.2, 0.3); cap.rotation.z = Math.PI / 5; group.add(cap);
    const box = new THREE.Mesh(
      new THREE.BoxGeometry(0.9, 0.9, 0.1),
      new THREE.MeshPhysicalMaterial({ color: 0x0D0E1F, transparent: true, opacity: 0.6, roughness: 0.1 })
    );
    box.position.set(-0.2, -0.7, 0.7); box.rotation.set(-0.2, 0.4, 0.1); group.add(box);
    const ring = new THREE.Mesh(
      new THREE.TorusGeometry(1.6, 0.005, 16, 100),
      new THREE.MeshBasicMaterial({ color: 0x00A88F, transparent: true, opacity: 0.2 })
    );
    ring.rotation.x = Math.PI / 2.2; group.add(ring);
    const clk = new THREE.Clock();
    (function anim() {
      requestAnimationFrame(anim);
      const t = clk.getElapsedTime();
      sphere.position.y = 0.2 + Math.sin(t * 1.5) * 0.08;
      cap.position.y = -0.2 + Math.sin(t * 1.8 + 1) * 0.1;
      box.position.y = -0.7 + Math.sin(t * 1.2 + 2) * 0.06;
      group.rotation.y += 0.003;
      ring.rotation.x += 0.001;
      rend.render(scene, cam);
    })();
    window.addEventListener('resize', () => {
      const nW = wrap.offsetWidth, nH = wrap.offsetHeight;
      cam.aspect = nW / nH; cam.updateProjectionMatrix(); rend.setSize(nW, nH);
    }, { passive: true });
    if (window.matchMedia('(hover:hover)').matches) {
      document.addEventListener('mousemove', e => {
        const fx = (e.clientX / innerWidth - .5) * .2;
        const fy = (e.clientY / innerHeight - .5) * .12;
        cam.position.x += (fx - cam.position.x) * .04;
        cam.position.y += (-fy - cam.position.y) * .04;
      }, { passive: true });
    }
  } catch (e) { console.warn('Three.js:', e); }
});
</script>
