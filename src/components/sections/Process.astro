---
import { PROCESS_STEPS } from '@/lib/constants';
---

<section class="section" id="proceso" aria-labelledby="process-h">
  <div class="s-tag">Proceso</div>
  <h2 class="s-headline" id="process-h">
    Cómo lo<br><em>hacemos realidad.</em>
  </h2>

  <div class="steps-grid">
    {PROCESS_STEPS.map(step => (
      <article class="card step-card" aria-labelledby={`step-${step.num}`}>
        <span class="step-num">{step.num}</span>
        <div class="step-icon" aria-hidden="true">{step.icon}</div>
        <h3 class="step-title" id={`step-${step.num}`}>
          {step.title}<br><em>{step.titleEm}</em>
        </h3>
        <p class="step-desc">{step.description}</p>
        <ul class="step-list">
          {step.items.map(item => <li>{item}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>

<style>
.steps-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1.2rem;
}
@media (max-width: 1100px) { .steps-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 600px)  { .steps-grid { grid-template-columns: 1fr; } }

.step-card {
  position: relative;
  overflow: visible; /* no clipear texto */
  min-width: 0;      /* permite que el grid comprima la celda */
}
.step-num {
  font-family: var(--mono); font-size: 3.2rem; font-weight: 700;
  line-height: 1; color: rgba(243,198,99,.06); margin-bottom: 1rem; display: block;
}
.step-icon {
  width: 44px; height: 44px;
  background: rgba(238,118,93,.1); border: 1px solid rgba(238,118,93,.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem; margin-bottom: 1.2rem; border-radius: .8rem;
  flex-shrink: 0;
}
.step-title {
  font-family: var(--body);
  font-size: clamp(1.1rem, 2.5vw, 1.4rem);
  font-weight: 800;
  letter-spacing: -.01em;
  line-height: 1.15;
  margin-bottom: .9rem;
  overflow-wrap: break-word;
  word-break: break-word;
  hyphens: auto;
}
.step-title em {
  font-family: var(--ser); color: var(--gr); font-size: .9em;
  font-style: italic; font-weight: 400;
}
.step-desc {
  font-family: var(--body); font-size: .88rem; color: var(--gr);
  line-height: 1.75; margin-bottom: 1.3rem;
  overflow-wrap: break-word;
}
.step-list { list-style: none; display: flex; flex-direction: column; gap: .5rem; }
.step-list li {
  font-family: var(--mono); font-size: .6rem; color: var(--gr);
  letter-spacing: .06em; display: flex; align-items: flex-start; gap: .55rem;
  overflow-wrap: break-word; word-break: break-word;
}
.step-list li::before {
  content: ''; width: 5px; height: 5px; background: var(--coral);
  border-radius: 50%; flex-shrink: 0; margin-top: .3em;
}
</style>
