---
import { NAV_LINKS } from '@/lib/constants';

interface Props {
  ctaLabel?: string;
  ctaHref?: string;
}

const { ctaLabel = 'AGENDAR DIAGNÓSTICO', ctaHref = '/contacto' } = Astro.props;
const pathname = Astro.url.pathname;
---

<header>
  <nav id="nav" aria-label="Navegación principal">
    <div class="nav-inner">
      <a href="/" class="nav-logo" aria-label="MUZA GROW — Inicio">
        <img src="/images/logo-white.png" alt="MUZA GROW" class="logo-img" height="36" />
        <img src="/images/logo-icon.png" alt="MUZA GROW" class="logo-icon" height="36" />
      </a>

      <ul class="nav-links" role="list">
        {NAV_LINKS.map(link => (
          <li>
            <a
              href={link.href}
              class:list={[{ active: pathname === link.href || pathname.startsWith(link.href.replace('/#', '/')) }]}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a href={ctaHref} class="nav-cta">{ctaLabel}</a>
    </div>
  </nav>
</header>

<script>
  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    nav?.classList.toggle('scrolled', window.scrollY > 60);
  }, { passive: true });
</script>

<style>
  .nav-links a.active { color: white; }
  .nav-logo { display: flex; align-items: center; }
  .logo-img { display: block; width: auto; max-height: 36px; object-fit: contain; }
  .logo-icon { display: none; width: auto; max-height: 36px; object-fit: contain; }
  @media (max-width: 480px) {
    .logo-img  { display: none; }
    .logo-icon { display: block; }
  }
</style>
