---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  target?: string;
  rel?: string;
  disabled?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  type = 'button',
  class: className = '',
  target,
  rel,
  disabled,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  href={href}
  type={href ? undefined : type}
  target={target}
  rel={rel}
  disabled={disabled}
  class:list={['btn', `btn-${variant}`, `btn-size-${size}`, className]}
>
  <slot />
</Tag>

<style>
.btn {
  font-family: var(--mono);
  font-weight: 700;
  letter-spacing: .14em;
  text-decoration: none;
  border-radius: 20px;
  display: inline-flex;
  align-items: center;
  gap: .45rem;
  cursor: pointer;
  transition: box-shadow .2s, transform .2s, background .2s, border-color .2s;
  white-space: nowrap;
  border: 1px solid transparent;
}
.btn:disabled { opacity: .6; cursor: not-allowed; pointer-events: none; }

/* Sizes */
.btn-size-sm { font-size: .58rem; padding: .45rem 1rem; }
.btn-size-md { font-size: .65rem; padding: .55rem 1.4rem; }
.btn-size-lg { font-size: .72rem; padding: .7rem 1.8rem; }

/* Variants */
.btn-primary { color: #051114; background: var(--white); border-color: transparent; }
.btn-primary:hover:not(:disabled) { box-shadow: 0 0 22px rgba(0,168,143,0.4); transform: translateY(-2px); }

.btn-outline { color: var(--white); background: var(--s2); border-color: var(--bdr); }
.btn-outline:hover:not(:disabled) { background: rgba(255,255,255,.08); border-color: var(--bdr-g); }

.btn-ghost { color: var(--gold); background: transparent; border-color: transparent; }
.btn-ghost:hover:not(:disabled) { color: var(--white); gap: .8rem; }
</style>
