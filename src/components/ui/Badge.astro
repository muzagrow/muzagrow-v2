---
interface Props {
  color?: 'default' | 'teal' | 'orange' | 'coral';
  class?: string;
}
const { color = 'default', class: className = '' } = Astro.props;
---

<span class:list={['badge', `badge-${color}`, className]}>
  <slot />
</span>

<style>
.badge {
  font-family: var(--mono);
  font-size: .52rem;
  letter-spacing: .07em;
  padding: .25rem .65rem;
  border-radius: 12px;
  display: inline-block;
}
.badge-default { color: var(--gr); background: var(--s2); border: 1px solid var(--bdr); }
.badge-teal { color: var(--teal); background: rgba(0,168,143,.1); border: 1px solid rgba(0,168,143,.25); }
.badge-orange { color: var(--orange); background: rgba(243,169,61,.1); border: 1px solid rgba(243,169,61,.25); }
.badge-coral { color: var(--coral); background: rgba(238,118,93,.1); border: 1px solid rgba(238,118,93,.25); }
</style>
